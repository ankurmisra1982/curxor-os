# CurXor Pro 128 — MS-S1 MAX 128GB UMA profile
# Copy to /etc/curxor/compute.env BEFORE first deploy.sh --pull-models
#
#   sudo cp /opt/curxor/pillar-1-compute/config/compute.env.pro128.example /etc/curxor/compute.env
#   sudo ln -sfn /etc/curxor/compute.env /opt/curxor/pillar-1-compute/.env

CURXOR_GFX_VERSION=11.5.1
CURXOR_ROCM_ARCH=gfx1151
CURXOR_TOTAL_RAM_GB=128
CURXOR_GPU_HEAP_GB=96

CURXOR_INFERENCE_BACKEND=ollama
CURXOR_MODELS_DIR=/var/lib/curxor/models
CURXOR_OLLAMA_DIR=/var/lib/curxor/ollama
CURXOR_HF_CACHE_DIR=/var/lib/curxor/huggingface

OLLAMA_IMAGE=ollama/ollama:rocm
OLLAMA_HOST_PORT=11434

# Default stack (Qwen3 generation — Jun 2026)
OLLAMA_VLA_MODEL=moondream:1.8b
OLLAMA_REASONING_MODEL=qwen3:8b
OLLAMA_EXTRA_MODELS=qwen3-vl:8b,qwen3:14b,batiai/qwen3.6-35b:q4

OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_NUM_PARALLEL=1
OLLAMA_KEEP_ALIVE=24h
OLLAMA_CONTEXT_LENGTH=8192
OLLAMA_KV_CACHE_TYPE=q8_0

VLLM_GPU_MEMORY_UTILIZATION=0.88
DOCKER_SHM_SIZE=16g
CURXOR_BIND_ADDRESS=127.0.0.1
