# CurXor OS — Pillar 1 Compute (.env)
# Copy to .env and adjust for your MS-S1 MAX BIOS UMA split.
# cp .env.example .env

# ── Hardware profile (Ryzen AI Max+ 395 / gfx1151) ──────────────────────────
CURXOR_GFX_VERSION=11.5.1
CURXOR_ROCM_ARCH=gfx1151

# Total system RAM (GB). MS-S1 MAX: 64 GB (Standard) or 128 GB (Pro) LPDDR5X UMA — soldered SKU.
CURXOR_TOTAL_RAM_GB=64

# GPU-accessible slice from BIOS (GB). Max this in BIOS for VLA workloads.
# Standard 64: 48 GB typical (~12–16 GB OS reserve)
# Pro 128:       96 GB typical (~16–32 GB OS reserve) — see docs/curxor-os/MS-S1-128GB-UNBOX-CHEATSHEET.md
CURXOR_GPU_HEAP_GB=48

# ── Pro 128 profile (uncomment when provisioning $4,999 SKU) ─────────────────
# CURXOR_TOTAL_RAM_GB=128
# CURXOR_GPU_HEAP_GB=96

# ── Runtime backend: ollama | vllm ────────────────────────────────────────
CURXOR_INFERENCE_BACKEND=ollama

# ── Model storage (host bind-mount; survives container rebuilds) ────────────
CURXOR_MODELS_DIR=/var/lib/curxor/models
CURXOR_OLLAMA_DIR=/var/lib/curxor/ollama
CURXOR_HF_CACHE_DIR=/var/lib/curxor/huggingface

# ── Ollama (default — most stable on gfx1151 UMA) ───────────────────────────
OLLAMA_IMAGE=ollama/ollama:rocm
OLLAMA_HOST_PORT=11434
# VLA / vision-language-action model for Phase 1 clawbot coordination
OLLAMA_VLA_MODEL=moondream:1.8b
# Reasoning backbone — aligned with CURXOR_INFERENCE_MODEL in engine.env / dashboard.env
OLLAMA_REASONING_MODEL=qwen3:8b
# Optional comma-separated pulls (Pro 128 example: qwen3-vl:8b,qwen3:14b,batiai/qwen3.6-35b:q4)
OLLAMA_EXTRA_MODELS=
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1
OLLAMA_KEEP_ALIVE=24h
OLLAMA_CONTEXT_LENGTH=8192
# Shrinks KV cache VRAM on gfx1151 UMA (~5% quality tradeoff, big headroom win)
OLLAMA_KV_CACHE_TYPE=q8_0

# ── vLLM (OpenAI-compatible API — experimental on gfx1151) ──────────────────
VLLM_IMAGE=rocm/vllm-dev:rocm7.2.1_navi_ubuntu24.04_py3.12_pytorch_2.9_vllm_0.16.0
VLLM_HOST_PORT=8000
VLLM_MODEL=OpenVLA/openvla-7b
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEMORY_UTILIZATION=0.88
VLLM_MAX_NUM_SEQS=4
VLLM_DTYPE=auto
# Trust remote code for VLA architectures (OpenVLA, etc.)
VLLM_TRUST_REMOTE_CODE=true

# ── Container resource limits (UMA-aware) ─────────────────────────────────
DOCKER_SHM_SIZE=16g
VLLM_IPC_MODE=host

# ── Network bind (localhost only — sovereign appliance) ─────────────────────
CURXOR_BIND_ADDRESS=127.0.0.1
