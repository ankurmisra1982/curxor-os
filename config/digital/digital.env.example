# CurXor OS — Digital bridge credentials
# Install: sudo cp config/digital/digital.env.example /etc/curxor/digital.env
# chmod 600 /etc/curxor/digital.env && chown root:curxor /etc/curxor/digital.env

# ── Alpaca Paper Trading (capital.execute_trade) ─────────────────────────────
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# ── X API v2 (content.publish_post) — LIVE TODAY ─────────────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=

# ── Meta (Instagram, Threads, Facebook Pages) — planned bridges ───────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_THREADS_USER_ID=
META_PAGE_ID=

# ── TikTok Content Posting API (content.publish_tiktok) — LIVE ───────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
# OAuth refresh (optional — rotate token without re-auth)
# TIKTOK_REFRESH_TOKEN=
# direct = post to profile · inbox = draft in TikTok app
TIKTOK_PUBLISH_MODE=direct
# SELF_ONLY required for unaudited apps; use PUBLIC_TO_EVERYONE after TikTok app audit
TIKTOK_DEFAULT_PRIVACY=SELF_ONLY

# ── YouTube Data API v3 (content.publish_youtube) — LIVE ─────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
# private · unlisted · public
YOUTUBE_DEFAULT_PRIVACY=private
# 22 = People & Blogs — https://developers.google.com/youtube/v3/docs/videoCategories/list
YOUTUBE_CATEGORY_ID=22

# ── LinkedIn UGC Posts API (content.publish_linkedin) — LIVE ─────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
# Optional — refresh without re-auth (requires client id/secret above)
# LINKEDIN_REFRESH_TOKEN=
# urn:li:person:… or urn:li:organization:… — auto-resolved from userinfo if unset
# LINKEDIN_AUTHOR_URN=
# PUBLIC · CONNECTIONS · LOGGED_IN
LINKEDIN_DEFAULT_VISIBILITY=PUBLIC

# ── Pinterest API (content.publish_pinterest) — LIVE ─────────────────────────
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
# Use refresh token (recommended) or a static access token
PINTEREST_REFRESH_TOKEN=
# PINTEREST_ACCESS_TOKEN=
# Board ID from GET /v5/boards — required for pin creation
PINTEREST_DEFAULT_BOARD_ID=
# Optional default destination link on pins
# PINTEREST_DEFAULT_LINK=https://yoursite.com

# ── Snapchat Marketing API (content.publish_snapchat) — LIVE ─────────────────
SNAP_CLIENT_ID=
SNAP_CLIENT_SECRET=
SNAP_REFRESH_TOKEN=
# Must match the redirect URI registered on your OAuth app
SNAP_REDIRECT_URI=https://your-host/oauth/snapchat/callback
# Public Profile UUID — from Business Manager / Public Profile API
SNAP_PUBLIC_PROFILE_ID=
# spotlight · story
SNAP_DEFAULT_FORMAT=spotlight
SNAP_DEFAULT_LOCALE=en_US

# ── Reddit OAuth (content.publish_reddit) — LIVE ─────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=
REDDIT_DEFAULT_SUBREDDIT=CurXor
REDDIT_USER_AGENT=CurXorOS/0.1 by your_reddit_username

# ── Bluesky AT Protocol (content.publish_bluesky) — LIVE ─────────────────────
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
# Default PDS — change only if self-hosting
# BLUESKY_PDS_URL=https://bsky.social

# ── Discord bot (channel.discord.send) — LIVE ────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# ── Telegram (channel.telegram.send) — messaging bridge LIVE ────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
# Operator chat IDs allowed to /approve /reject /approvals (falls back to TELEGRAM_DEFAULT_CHAT_ID)
# CURXOR_APPROVAL_TELEGRAM_CHAT_IDS=123456789,-1009876543210
# CURXOR_APPROVAL_TELEGRAM_NOTIFY=1
# Alert operators on bridge publish failure (uses same chat IDs; set to 0 to disable)
# CURXOR_PUBLISH_FAILURE_NOTIFY=1

# ── WhatsApp Cloud API (channel.whatsapp.send) — messaging bridge LIVE ─────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Optional overrides (defaults match mesh broker env)
# CURXOR_TOPIC_DIGITAL_OUT=telemetry/digital_out
# CURXOR_TOPIC_DIGITAL_IN=telemetry/digital_in

# ── Creator Claw assets (thumbnails, rendered video) ─────────────────────────
# CURXOR_CONTENT_ASSETS_PATH=/etc/curxor/content-assets
# CURXOR_CONTENT_QUEUE_PATH=/etc/curxor/content-queue.json
# CURXOR_CONTENT_JOBS_PATH=/etc/curxor/content-jobs.json
# CURXOR_CONTENT_ANALYTICS_PATH=/etc/curxor/content-analytics.json
# CURXOR_CONTENT_REPLIES_PATH=/etc/curxor/content-replies.json
# CURXOR_CONTENT_CAMPAIGNS_PATH=/etc/curxor/content-campaigns.json
# CURXOR_METRICS_PULL_INTERVAL_HOURS=6
# CURXOR_METRICS_PULL_STATE_PATH=/etc/curxor/content-metrics-pull-state.json
# CURXOR_ENGAGE_INBOX_PATH=/etc/curxor/engage-inbox.json
# Poll X mentions, LinkedIn comments, Threads replies into engage inbox (heartbeat)
# CURXOR_SOCIAL_ENGAGE_POLL_ENABLED=true
# CURXOR_SOCIAL_ENGAGE_POLL_INTERVAL_MINUTES=15
# CURXOR_SOCIAL_ENGAGE_STATE_PATH=/etc/curxor/social-engage-poll-state.json
# X user id cache (optional — resolved via /2/users/me if unset)
# X_USER_ID=
# Meta/Threads webhook verify token (GET hub.verify_token on /api/engage/social/webhook)
# META_WEBHOOK_VERIFY_TOKEN=curxor-social-engage
# CURXOR_SOCIAL_WEBHOOK_VERIFY_TOKEN=curxor-social-engage
# Auto-route channel webhooks (Telegram/Slack/WhatsApp/iMessage) to Creator engage inbox
# CURXOR_ENGAGE_INBOX_AUTO=true
# CURXOR_ENGAGE_INBOX_CHANNELS=telegram,slack,whatsapp,imessage
# Engage Claw (claw-cafe): capture-only — ack without full agent reply
# CURXOR_ENGAGE_CAPTURE_ONLY=true
# LinkedIn analytics API version for live metrics pull
# CURXOR_LINKEDIN_API_VERSION=202405
# CURXOR_CONTENT_EXPORT_PATH=/tmp/curxor-content-exports
# Outbound webhooks on publish receipt (comma-separated URLs)
# CURXOR_CONTENT_WEBHOOK_URLS=https://hooks.n8n.io/xxx
# CURXOR_CONTENT_WEBHOOK_SECRET=optional-shared-secret
# Optional music bed for video render
# CURXOR_MUSIC_BED_PATH=/etc/curxor/assets/royalty-free-bed.mp3
# Optional S3-compatible CDN sync
# CURXOR_CDN_SYNC_ENDPOINT=https://s3.example.com/bucket
# CURXOR_CDN_SYNC_TOKEN=...
# CURXOR_CDN_PUBLIC_BASE=https://cdn.example.com/bucket
# Public base URL for image_url / video_url in publish payloads (IG, Pinterest)
# CURXOR_CONTENT_PUBLIC_BASE=http://eno2:3000

# CURXOR_REQUIRE_PUBLISH_APPROVAL=true
# CURXOR_REQUIRE_REPLY_APPROVAL=true
# CURXOR_CONTENT_AUDIT_PATH=/etc/curxor/content-audit.json
# CURXOR_APPROVAL_TELEGRAM_CHAT_IDS=123456789
# CURXOR_APPROVAL_TELEGRAM_NOTIFY=1

# CURXOR_METRICS_RULES_ENABLED=true
# CURXOR_METRICS_RULES_PATH=/etc/curxor/content-metrics-rules.json

# CURXOR_BRIDGE_HEALTH_PATH=/etc/curxor/content-bridge-health.json

# ── Outreach Claw SMTP (work.email.send) ─────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# TLS on port 587 (set 0 for plain SMTP on port 25)
SMTP_USE_TLS=1

# Optional: require human approval before each send (dashboard or Telegram)
# CURXOR_WORK_REQUIRE_APPROVAL=0
# CURXOR_WORK_FAILURE_NOTIFY=1

# ── Creator Claw TTS (video voiceover) ───────────────────────────────────────
# auto · piper · espeak · off
# CURXOR_TTS_ENGINE=auto
# CURXOR_TTS_VOICE=en-us
# CURXOR_PIPER_BIN=piper
# CURXOR_PIPER_MODEL=/etc/curxor/models/en_US-lessac-medium.onnx

# ── Creator Claw AI image gen (Ollama) ───────────────────────────────────────
# CURXOR_IMAGE_MODEL=flux
