# CurXor OS — OTA update daemon configuration
# Copy to /etc/curxor/ota.env and adjust for your release channel.

# Remote manifest (mock GitHub Releases-style endpoint)
# Example: raw GitHub release asset or internal mirror
CURXOR_OTA_VERSION_URL=https://raw.githubusercontent.com/curxor/curxor-os/main/config/ota/mock-release/version.json

# Local install root and version file
CURXOR_OTA_ROOT=/opt/curxor
CURXOR_OTA_LOCAL_VERSION=${CURXOR_OTA_ROOT}/version.json

# Staging, backups, logs
CURXOR_OTA_STAGING_DIR=/var/lib/curxor/ota/staging
CURXOR_OTA_BACKUP_DIR=/var/backups/curxor
CURXOR_OTA_LOG=/var/log/curxor/ota-update.log

# Require HTTPS for manifest + artifact downloads
CURXOR_OTA_REQUIRE_HTTPS=1

# Verify sha256 from manifest when present (strongly recommended)
CURXOR_OTA_VERIFY_SHA256=1

# Seconds to wait after restart before health check
CURXOR_OTA_HEALTH_WAIT_SEC=15
