# CurXor OS — ops@curxor.ai bridge credentials (local dev)
# Copy: npm run setup:ops-env  (from pillar-4-dashboard)
# Edit: config/local/ops-digital.env — NEVER commit that file
#
# Full catalog: config/digital/digital.env.example

# ── Live money gate ───────────────────────────────────────────────────────────
CURXOR_CAPITAL_LIVE_ENABLED=0

# ── Wave 1 · Alpaca Paper (ops@curxor.ai account) ─────────────────────────────
# https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# ── Wave 0.5 · Google Workspace OAuth (Work Claw + YouTube later) ─────────────
# Cloud project: curxor-ops · redirect: http://127.0.0.1:3080/api/work/google
CURXOR_GOOGLE_OAUTH_CLIENT_ID=
CURXOR_GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_WORKSPACE_REDIRECT_URI=http://127.0.0.1:3080/api/work/google
CURXOR_WORK_GOOGLE_OAUTH_PATH=

# ── Work · SMTP/IMAP (ops@curxor.ai mailbox) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ops@curxor.ai
SMTP_PASS=
SMTP_FROM=ops@curxor.ai
SMTP_USE_TLS=1
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=ops@curxor.ai
IMAP_PASS=
IMAP_USE_TLS=1

# ── Wave 1 · Bluesky (fast publish smoke) ─────────────────────────────────────
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# ── Wave 1 · X / Twitter (developer.x.com — OAuth 1.0a User context) ─────────
# Dev portal login: often curxorsystems@gmail.com (@curxorai) or ops@ for @curxoros app
# https://developer.x.com/en/portal/dashboard
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# X_BEARER_TOKEN=   # optional — read/search only

# ── Wave 1 · Telegram (approvals + messaging) ───────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# ── Wave 1 · Discord ──────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# ── Wave 2 · defer until Wave 1 smoke green ───────────────────────────────────
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=
