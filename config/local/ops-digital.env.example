# MICROSOFT_CLIENT_SECRET=
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# GARMIN_CLIENT_ID=
# GARMIN_CLIENT_SECRET=
# GARMIN_REDIRECT_URI=http://127.0.0.1:3080/api/vital/garmin/callback
# SLACK_BOT_TOKEN=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
