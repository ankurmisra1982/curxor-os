# CurXor OS — founder deploy sudo override (generated by install-deploy-sudo-override.sh)
# Passwordless deploy for the laptop operator only — re-run install-deploy-sudo-override.sh to update.

Cmnd_Alias CURXOR_DEPLOY = __CURXOR_ROOT__/scripts/box-apply-deploy.sh, \
                           __CURXOR_ROOT__/scripts/post-update.sh, \
                           __CURXOR_ROOT__/scripts/install-deploy-sudo-override.sh, \
                           __CURXOR_ROOT__/scripts/verify-deploy-sudo-override.sh

__DEPLOY_USER__ ALL=(root) NOPASSWD: CURXOR_DEPLOY
