# CurXor OS — Pillar 2 Engine (OpenClaw Pivot)

# ── Local inference (Pillar 1) — NO cloud endpoints ─────────────────────────
CURXOR_INFERENCE_BACKEND=ollama
CURXOR_INFERENCE_BASE_URL=http://127.0.0.1:11434
CURXOR_OLLAMA_URL=http://127.0.0.1:11434
CURXOR_INFERENCE_MODEL=qwen2.5:7b-instruct-q4_K_M
CURXOR_INFERENCE_TIMEOUT_MS=30000
CURXOR_MIN_REASON_INTERVAL_MS=500

# ── Robotics mesh (Pillar 3 broker on eno2) ─────────────────────────────────
CURXOR_MESH_BROKER_IP=10.77.0.1
CURXOR_VISION_XPUB_PORT=9101
CURXOR_MOTOR_XSUB_PORT=9200
CURXOR_TOPIC_VISION=telemetry/vision_in
CURXOR_TOPIC_MOTOR=telemetry/motor_out
CURXOR_TOPIC_DIGITAL_OUT=telemetry/digital_out

# ── Agent loop ───────────────────────────────────────────────────────────────
CURXOR_CLAW_ID=1
CURXOR_LOOP_INTERVAL_MS=50
CURXOR_AGENT_SYSTEM_PROMPT=You are CurXor, a sovereign edge agent controlling a physical claw bot. Output only physical motor actions. Never suggest cloud APIs or digital tools.

# Active claw profile (written by dashboard claw wizard)
# CURXOR_ACTIVE_CLAW_CONF=/etc/curxor/engine.env.d/active-claw.conf
