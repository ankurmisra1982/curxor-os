{
  "name": "@curxor/dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "CurXor OS Pillar 4 — Local captive portal dashboard",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3080",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3080",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "ci:prepare-qa": "node scripts/ci-prepare-qa.mjs",
    "qa:smoke": "node scripts/qa-smoke.mjs",
    "qa:flows": "node scripts/qa-user-flows.mjs",
    "heartbeat:daemon": "node scripts/heartbeat-daemon.mjs",
    "qa:wait": "node scripts/wait-for-server.mjs",
    "qa:local": "node scripts/qa-local.mjs",
    "qa:capital-checklist": "node scripts/capital-checklist.mjs",
    "qa:creator-checklist": "node scripts/creator-checklist.mjs",
    "qa:work-checklist": "node scripts/work-checklist.mjs",
    "qa:work-levels": "node scripts/qa-work-levels.mjs",
    "setup:capital-env": "node scripts/setup-capital-env.mjs",
    "setup:work-env": "node scripts/setup-work-env.mjs",
    "configure:capital-keys": "node scripts/configure-capital-keys.mjs --open-signup-pages",
    "verify:exit-demo-scaffold": "node scripts/verify-exit-demo-scaffold.mjs",
    "verify:work-exit-demo-scaffold": "node scripts/verify-work-exit-demo-scaffold.mjs",
    "verify:work-live-proof": "node scripts/verify-work-live-proof.mjs",
    "demo:capture": "node scripts/capture-demo-screenshots.mjs",
    "demo:capture:capital": "node scripts/capture-capital-demo.mjs",
    "demo:capture:work": "node scripts/capture-work-demo.mjs",
    "demo:capture:work:levels": "node scripts/capture-gtm-phase2.mjs",
    "demo:record:work:exit": "node scripts/record-work-exit-demo.mjs",
    "demo:record:work": "node scripts/record-outreach-walkthrough.mjs",
    "demo:capture:marketing": "node scripts/capture-marketing-flows.mjs",
    "qa:work-excellence": "node scripts/work-checklist.mjs && node scripts/qa-work-levels.mjs"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.0",
    "@fontsource/fira-code": "^5.2.0",
    "lightweight-charts": "^5.2.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zeromq": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  }
}
