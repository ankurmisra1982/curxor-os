# CurXor OS — Pillar 4 Dashboard

# Server-side mesh (ZMQ XPUB subscribe — same as Pillar 2 engine)
CURXOR_MESH_BROKER_IP=10.77.0.1
CURXOR_VISION_XPUB_PORT=9101
CURXOR_MOTOR_XPUB_PORT=9201
CURXOR_MOTOR_XSUB_PORT=9200
CURXOR_TOPIC_VISION=telemetry/vision_in
CURXOR_TOPIC_MOTOR=telemetry/motor_out
CURXOR_TOPIC_DIGITAL_IN=telemetry/digital_in
CURXOR_TOPIC_DIGITAL_OUT=telemetry/digital_out
CURXOR_TOPIC_CLAW_CONTEXT=telemetry/claw_context

# Pillar 1 local inference (localhost only) — align with compute.env
CURXOR_INFERENCE_BACKEND=ollama
CURXOR_INFERENCE_BASE_URL=http://127.0.0.1:11434
CURXOR_INFERENCE_MODEL=qwen3:8b
CURXOR_INFERENCE_TIMEOUT_MS=30000
# Set to 0 to force rule-based dashboard chat (no Ollama calls)
CURXOR_DASHBOARD_INFERENCE_ENABLED=1
CURXOR_INFERENCE_METRICS_URL=http://127.0.0.1:8000/metrics
CURXOR_OLLAMA_URL=http://127.0.0.1:11434

# UMA / system memory
CURXOR_TOTAL_RAM_GB=64
CURXOR_GPU_HEAP_GB=48

# Dashboard bind (captive portal)
PORT=3080
HOSTNAME=0.0.0.0

# Flight Command shell v2 (UX-1 hybrid layout). Default-on in production via .env.production.
# Unset or 0 in .env.local to use legacy AppNav during local dev.
# NEXT_PUBLIC_CURXOR_SHELL_V2=1

# First Run Experience state file (production: /etc/curxor/…)
# Local QA: pillar-4-dashboard/scripts/dev-qa/fre-state.json
# Run: npm run setup:capital-env — creates .env.local + scripts/dev-qa/digital.env
# Runtime JSON (XP, Cafe, swarm queue): defaults to /etc/curxor when NODE_ENV=production
# CURXOR_DATA_DIR=/etc/curxor
# CURXOR_DEV_QA_DIR=scripts/dev-qa  (set by npm run qa:local only)
CURXOR_FRE_STATE_PATH=/etc/curxor/fre-state.json
CURXOR_USER_SETTINGS_PATH=/etc/curxor/user-settings.json
CURXOR_LLM_CREDENTIALS_PATH=/etc/curxor/llm-credentials.json
# Sakana API key stored via Settings → Intelligence (llm-credentials.json)
CURXOR_CLAW_CONTEXT_PATH=/etc/curxor/claw-context.json
CURXOR_FAMILY_PROFILES_PATH=/etc/curxor/family-profiles.json
CURXOR_VITAL_STATE_PATH=/etc/curxor/vital-health.json
CURXOR_DIGITAL_ENV_PATH=/etc/curxor/digital.env
CURXOR_APP_FRE_DIR=/etc/curxor/app-fre
CURXOR_CLAW_PROFILES_PATH=/etc/curxor/claw-profiles.json
CURXOR_ACTIVE_CLAW_CONF=/etc/curxor/engine.env.d/active-claw.conf
CURXOR_APPLY_CLAW_SCRIPT=/opt/curxor/scripts/apply-active-claw.sh
CURXOR_OTA_LOG=/var/log/curxor/ota-update.log

# Optional LAN token for mutating API routes (mesh, provision, claw create, app FRE).
# Unset = open (dev). When set, LAN clients must send Authorization: Bearer <token>
# or X-CurXor-Token header. Localhost (127.0.0.1) always bypasses.
# CURXOR_LAN_AUTH_TOKEN=

# OAuth provider link sessions (production: /etc/curxor/…)
# CURXOR_PROVIDER_LINK_SESSIONS_PATH=/etc/curxor/provider-link-sessions.json

# Google OAuth (optional — enables Settings → Sign in with Google AI)
# OpenAI OAuth uses the public Codex client ID; no env vars required.
# CURXOR_GOOGLE_OAUTH_CLIENT_ID=
# CURXOR_GOOGLE_OAUTH_CLIENT_SECRET=
