# CurXor Capital — local dev digital.env template
# Copy: cp scripts/dev-qa/digital.env.example scripts/dev-qa/digital.env
# Then paste your keys from each provider dashboard (never commit digital.env).

# ── Live money gate (desk FRE + go-live) ─────────────────────────────────────
# Demo release: leave 0. Set 1 only when exercising live-money (see RELEASE-NEXT.md)
CURXOR_CAPITAL_LIVE_ENABLED=0

# ── Alpaca Paper Trading ─────────────────────────────────────────────────────
# https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
# ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# ── Plaid (sandbox PFM bank link) ────────────────────────────────────────────
# https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── SnapTrade (unified broker OAuth) ─────────────────────────────────────────
# https://snaptrade.com/ — register app for clientId + consumerSecret
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_SECRET=
SNAPTRADE_REDIRECT_URI=http://127.0.0.1:3080/api/capital/snaptrade

# ── Webull OAuth (pillar-3 bridge when linked) ───────────────────────────────
# https://developer.webull.com/
WEBULL_CLIENT_ID=
WEBULL_CLIENT_SECRET=
WEBULL_OAUTH_API_BASE=https://us-oauth-open-api.uat.webullbroker.com

# ── E*TRADE OAuth 1.0a (pillar-3 bridge when linked) ────────────────────────
ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=
ETRADE_SANDBOX=1

# ── Robinhood Agentic MCP (optional — link via desk, not sovereign fill yet) ─
# ROBINHOOD_MCP_ENABLED=1

# ── TradingView webhook (optional) ─────────────────────────────────────────────
# CURXOR_CAPITAL_TV_SECRET=your-tradingview-webhook-secret

# ── Quiver congressional feed (optional) ───────────────────────────────────────
# QUIVER_API_KEY=

# ── Local state paths (dev-qa — set automatically by qa-local / setup script) ─
# CURXOR_CAPITAL_PLAID_PATH=
# CURXOR_CAPITAL_SNAPTRADE_PATH=

# ── Arbitrage Claw — commerce bridges (eno2 read paths) ─────────────────────
# Files preferred on appliance: /etc/curxor/commerce-shopify.json, commerce-ebay.json, commerce-printify.json
# Dev mock sync: CURXOR_SHOPIFY_MOCK=1 CURXOR_EBAY_MOCK=1 CURXOR_PRINTIFY_MOCK=1 (see docs/arbitrage-claw/FREEZE.md)
# SHOPIFY_SHOP_DOMAIN=my-store.myshopify.com
# SHOPIFY_ACCESS_TOKEN=
# EBAY_ACCESS_TOKEN=
# EBAY_ENVIRONMENT=production
# PRINTIFY_API_TOKEN=
# PRINTIFY_SHOP_ID=

# ── Build Plane — OS event bus webhooks (BP2 / v0.8.2) ───────────────────────
# CURXOR_BUILD_PLANE_WEBHOOK_URL=https://your-automation-endpoint
# CURXOR_ENO2_DOWN=1  # optional — force eno2.down on health poll (demo)
# CURXOR_OTA_MANIFEST_PATH=/path/to/ota/version.json
# CURXOR_BUILD_WORKER_ONLINE=1  # force worker online on probe (demo)
# CURXOR_BUILD_WORKER_HOST=10.0.0.1
