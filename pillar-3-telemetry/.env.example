# CurXor OS — Pillar 3 Telemetry Broker
# Copy to /etc/curxor/telemetry-broker.env

# Strict bind: secondary 10GbE robotics mesh interface only
CURXOR_MESH_IFACE=enp97s0
# Leave empty to auto-detect IPv4 from CURXOR_MESH_IFACE at startup
CURXOR_MESH_BIND_IP=

# Topic prefixes (first ZMQ frame on every multipart message)
CURXOR_TOPIC_VISION=telemetry/vision_in
CURXOR_TOPIC_MOTOR=telemetry/motor_out
CURXOR_TOPIC_DIGITAL_OUT=telemetry/digital_out
CURXOR_TOPIC_DIGITAL_IN=telemetry/digital_in

# Vision proxy — high throughput, larger buffers
CURXOR_VISION_XSUB_PORT=9100
CURXOR_VISION_XPUB_PORT=9101
CURXOR_VISION_RCVHWM=4096
CURXOR_VISION_SNDHWM=4096

# Motor proxy — minimal buffering for sub-ms mechanical latency
CURXOR_MOTOR_XSUB_PORT=9200
CURXOR_MOTOR_XPUB_PORT=9201
CURXOR_MOTOR_RCVHWM=16
CURXOR_MOTOR_SNDHWM=16

# libzmq I/O threads (2 is optimal for dual-proxy on one NIC)
CURXOR_ZMQ_IO_THREADS=2

# Drop stale motor frames when publisher exceeds link rate (last-value wins)
CURXOR_MOTOR_CONFLATE=0
